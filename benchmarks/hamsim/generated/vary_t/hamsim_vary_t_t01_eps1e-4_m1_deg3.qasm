OPENQASM 2.0;
include "qelib1.inc";

opaque UH a0, s0;
opaque UHdg a0, s0;
opaque cUH c, a0, s0;
opaque cUHdg c, a0, s0;
opaque mcx selector, c0, t;

qreg q[5];

// q[0] = Hamiltonian-simulation selector ancilla
// q[1] = QSP imaginary-part extraction selector ancilla
// q[2] = QSP phase ancilla
// q[3] = block-encoding ancilla[0]
// q[4] = system qubit[0]

// Full Hamiltonian simulation QSP block generated by tools/hamsim_qsp.py.
// The outer selector multiplexes the QSP phases: each common layer applies the
// cosine signed phase, then selector |1> adds the sine-cosine phase difference.
// The common U_H/U_Hdg skeleton is shared; only the sine branch has the final
// extra U_H and phase. The component selector extracts pyqsp's imaginary
// response before the outer sdg+h combines P_cos(H) - i P_sin(H).
//
// P_cos(x) = 0.49999973969181999 - 0.0024979173175998385*x^2
// P_sin(x) = 0.049999986983506273*x - 8.3281263019025089e-05*x^3
// Expected all-zero selector branch = 0.24999986984590999 - 0.024999993491753136*i*x - 0.0012489586587999192*x^2 + 4.1640631509512544e-05*i*x^3
//
// QSP phases:
//   cos phi_0 = -0.00072048808231031756
//   cos phi_1 = 0.52215749885570872
//   cos phi_2 = -0.00072048808231031756
//   sin phi_0 = -1.041665607948222e-05
//   sin phi_1 = 0.024979145849470877
//   sin phi_2 = 0.024979145849470877
//   sin phi_3 = -1.041665607948222e-05

h q[0];
h q[1];

// common phase 0
// cos phi_0 = -0.00072048808231
// cos psi_0 = 0.784677675315
// sin phi_0 = -1.04166560795e-05
// sin psi_0 = 0.785387746741
// Delta_0 = sin psi_0 - cos psi_0 = 0.000710071426231
// base cos signed phase
x q[1];
cx q[1], q[2];
x q[1];

x q[3];
mcx q[3], q[2];
x q[3];
rz(-1.56935535063) q[2];
x q[3];
mcx q[3], q[2];
x q[3];

x q[1];
cx q[1], q[2];
x q[1];

// extra signed difference phase on sin branch only
x q[1];
mcx q[0], q[1], q[2];
x q[1];

x q[3];
mcx q[0], q[3], q[2];
x q[3];
mcx q[0], q[2];
rz(0.000710071426231) q[2];
mcx q[0], q[2];
rz(-0.000710071426231) q[2];
x q[3];
mcx q[0], q[3], q[2];
x q[3];

x q[1];
mcx q[0], q[1], q[2];
x q[1];

// common U
UH q[3], q[4];

// common phase 1
// cos phi_1 = 0.522157498856
// cos psi_1 = 2.09295382565
// sin phi_1 = 0.0249791458495
// sin psi_1 = 1.59577547264
// Delta_1 = sin psi_1 - cos psi_1 = -0.497178353006
// base cos signed phase
x q[1];
cx q[1], q[2];
x q[1];

x q[3];
mcx q[3], q[2];
x q[3];
rz(-4.1859076513) q[2];
x q[3];
mcx q[3], q[2];
x q[3];

x q[1];
cx q[1], q[2];
x q[1];

// extra signed difference phase on sin branch only
x q[1];
mcx q[0], q[1], q[2];
x q[1];

x q[3];
mcx q[0], q[3], q[2];
x q[3];
mcx q[0], q[2];
rz(-0.497178353006) q[2];
mcx q[0], q[2];
rz(0.497178353006) q[2];
x q[3];
mcx q[0], q[3], q[2];
x q[3];

x q[1];
mcx q[0], q[1], q[2];
x q[1];

// common U^\dagger
UHdg q[3], q[4];

// common phase 2
// cos phi_2 = -0.00072048808231
// cos psi_2 = 0.784677675315
// sin phi_2 = 0.0249791458495
// sin psi_2 = 1.59577547264
// Delta_2 = sin psi_2 - cos psi_2 = 0.811097797329
// base cos signed phase
x q[1];
cx q[1], q[2];
x q[1];

x q[3];
mcx q[3], q[2];
x q[3];
rz(-1.56935535063) q[2];
x q[3];
mcx q[3], q[2];
x q[3];

x q[1];
cx q[1], q[2];
x q[1];

// extra signed difference phase on sin branch only
x q[1];
mcx q[0], q[1], q[2];
x q[1];

x q[3];
mcx q[0], q[3], q[2];
x q[3];
mcx q[0], q[2];
rz(0.811097797329) q[2];
mcx q[0], q[2];
rz(-0.811097797329) q[2];
x q[3];
mcx q[0], q[3], q[2];
x q[3];

x q[1];
mcx q[0], q[1], q[2];
x q[1];

// sin-only final U
cUH q[0], q[3], q[4];

// final sin-only phase 3
// sin phi_3 = -1.04166560795e-05
// sin psi_3 = -0.785408580054
x q[1];
mcx q[0], q[1], q[2];
x q[1];

x q[3];
mcx q[0], q[3], q[2];
x q[3];
mcx q[0], q[2];
rz(-0.785408580054) q[2];
mcx q[0], q[2];
rz(0.785408580054) q[2];
x q[3];
mcx q[0], q[3], q[2];
x q[3];

x q[1];
mcx q[0], q[1], q[2];
x q[1];

// extract pyqsp imaginary response on the component selector
h q[1];
s q[1];
x q[1];

// combine 1/2 * (E_cos - i E_sin)
sdg q[0];
h q[0];
